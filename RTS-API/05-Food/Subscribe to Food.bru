meta {
  name: Subscribe to Food
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/food/subscribe
  body: none
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

docs {
  # Subscribe to Food

  Opts the authenticated user into the food program.
  Subscription starts from the next Monday (or this Monday if today is Monday).
  No request body required.
}
