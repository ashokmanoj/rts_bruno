meta {
  name: Cancel Year
  type: http
  seq: 5
}

post {
  url: {{baseUrl}}/food/cancel
  body: none
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

docs {
  # Cancel Year (Button 2)

  Suspends food from next Monday through the rest of the year
  by setting suspendedFrom = next Monday on the FoodSubscription.
  Can be undone before Sunday 10:30 AM IST.
}
