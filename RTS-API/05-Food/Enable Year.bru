meta {
  name: Enable Year
  type: http
  seq: 9
}

post {
  url: {{baseUrl}}/food/enable-year
  body: none
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

docs {
  # Enable Year (Button 4)

  Clears isActive=true and suspendedFrom=null on the FoodSubscription,
  re-enabling food for the rest of the year.
}
