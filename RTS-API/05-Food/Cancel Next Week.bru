meta {
  name: Cancel Next Week
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/food/cancel-week
  body: none
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

docs {
  # Cancel Next Week (Button 1)

  Creates a single-week FoodCancellation for the upcoming Monday.
  Only affects next week — all other weeks remain active.
  Can be undone before Sunday 10:30 AM IST.
}
