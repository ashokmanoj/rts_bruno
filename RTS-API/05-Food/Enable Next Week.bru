meta {
  name: Enable Next Week
  type: http
  seq: 7
}

post {
  url: {{baseUrl}}/food/enable-next-week
  body: none
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

docs {
  # Enable Next Week Only (Button 3)

  When the year is suspended, enables food for next week only by setting
  suspendedFrom = week-after-next. Also removes any next-week cancellation.
  Can be undone before Sunday 10:30 AM IST.
}
